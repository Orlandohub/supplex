### 8.3 Test Database Management

```typescript
// tests/utils/database.ts

export class TestDatabase {
  private static connection;

  static async setup() {
    // Create test database
    this.connection = await createConnection({
      host: process.env.TEST_DB_HOST || "localhost",
      port: process.env.TEST_DB_PORT || 5432,
      database: `supplex_test_${process.pid}`, // Isolated per test process
      username: process.env.TEST_DB_USER || "postgres",
      password: process.env.TEST_DB_PASSWORD || "postgres",
    });

    // Run migrations
    await this.connection.runMigrations();
  }

  static async teardown() {
    if (this.connection) {
      await this.connection.dropDatabase();
      await this.connection.close();
    }
  }

  static async reset() {
    // Truncate all tables (faster than drop/recreate)
    await this.connection.query(
      "TRUNCATE TABLE suppliers, evaluations, complaints, users, tenants CASCADE"
    );
  }

  static async seed(data) {
    // Seed with specific data
    for (const [table, rows] of Object.entries(data)) {
      await this.connection.getRepository(table).save(rows);
    }
  }
}

// Global test setup (jest.setup.ts)
beforeAll(async () => {
  await TestDatabase.setup();
});

afterAll(async () => {
  await TestDatabase.teardown();
});

beforeEach(async () => {
  await TestDatabase.reset();
});
```

