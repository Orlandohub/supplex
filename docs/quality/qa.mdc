```typescript
// api/suppliers.integration.test.ts
describe("Suppliers API", () => {
  let authToken;

  beforeAll(async () => {
    await setupTestDatabase();
    authToken = await loginTestUser();
  });

  afterAll(async () => {
    await cleanupTestDatabase();
  });

  describe("GET /api/v1/suppliers", () => {
    beforeEach(async () => {
      await seedSuppliers(10);
    });

    it("should return paginated suppliers", async () => {
      const response = await request(app)
        .get("/api/v1/suppliers?page=1&per_page=5")
        .set("Authorization", `Bearer ${authToken}`)
        .expect(200);

      expect(response.body.data).toHaveLength(5);
      expect(response.body.meta.total_pages).toBe(2);
      expect(response.body.meta.current_page).toBe(1);
    });

    it("should filter by status", async () => {
      const response = await request(app)
        .get("/api/v1/suppliers?status=approved")
        .set("Authorization", `Bearer ${authToken}`)
        .expect(200);

      response.body.data.forEach((supplier) => {
        expect(supplier.status).toBe("approved");
      });
    });

    it("should search by name", async () => {
      await createSupplier({ name: "Acme Manufacturing" });

      const response = await request(app)
        .get("/api/v1/suppliers?search=Acme")
        .set("Authorization", `Bearer ${authToken}`)
        .expect(200);

      expect(response.body.data.length).toBeGreaterThan(0);
      expect(response.body.data[0].name).toContain("Acme");
    });
  });

  describe("POST /api/v1/suppliers", () => {
    it("should create supplier with valid data", async () => {
      const supplierData = {
        name: "New Supplier Inc",
        status: "prospect",
        category_id: "uuid",
        contact_info: {
          primary_contact: {
            name: "John Doe",
            email: "john@newsupplier.com",
            phone: "+1-555-0100",
          },
        },
      };

      const response = await request(app)
        .post("/api/v1/suppliers")
        .set("Authorization", `Bearer ${authToken}`)
        .send(supplierData)
        .expect(201);

      expect(response.body.id).toBeDefined();
      expect(response.body.name).toBe("New Supplier Inc");
      expect(response.body.code).toMatch(/^SUP-\d{4}-\d{4}$/);
    });

    it("should reject invalid data", async () => {
      const response = await request(app)
        .post("/api/v1/suppliers")
        .set("Authorization", `Bearer ${authToken}`)
        .send({ status: "approved" }) // Missing required 'name'
        .expect(400);

      expect(response.body.error).toBe("validation_error");
      expect(response.body.details.name).toContain("Name is required");
    });

    it("should enforce tenant isolation", async () => {
      // Create supplier in tenant A
      const supplierA = await createSupplier({ tenant: "tenant-a" });

      // Login as tenant B
      const tokenB = await loginTestUser({ tenant: "tenant-b" });

      // Try to access tenant A's supplier
      await request(app)
        .get(`/api/v1/suppliers/${supplierA.id}`)
        .set("Authorization", `Bearer ${tokenB}`)
        .expect(404); // Not 403, to avoid leaking existence
    });
  });
});
```

