## 5. Multi-Tenancy Testing

### 5.1 Test Strategy

**Critical Requirement:** Zero cross-tenant data leakage

**Test Categories:**

1. **Data Isolation Tests** - Verify tenant data is isolated
2. **RLS Policy Tests** - Test Row-Level Security enforcement
3. **API Authorization Tests** - Verify JWT-based tenant filtering
4. **File Storage Tests** - Verify file isolation
5. **Cache Isolation Tests** - Verify cache keys include tenant_id

### 5.2 Automated Test Suite

```typescript
// tests/multi-tenancy.test.ts
describe("Multi-Tenancy Isolation", () => {
  let tenantA, tenantB, tenantC;

  beforeAll(async () => {
    // Create 3 tenants with test data
    tenantA = await createTenant({ name: "Tenant A" });
    tenantB = await createTenant({ name: "Tenant B" });
    tenantC = await createTenant({ name: "Tenant C" });

    await seedData(tenantA, {
      suppliers: 10,
      evaluations: 20,
      complaints: 5,
    });
    await seedData(tenantB, {
      suppliers: 15,
      evaluations: 30,
      complaints: 8,
    });
    await seedData(tenantC, {
      suppliers: 5,
      evaluations: 10,
      complaints: 2,
    });
  });

  describe("Supplier Isolation", () => {
    it("should only return suppliers from user tenant", async () => {
      const userA = await createUser({ tenant: tenantA });
      const response = await api.get("/suppliers", { auth: userA });

      expect(response.data).toHaveLength(10);
      response.data.forEach((supplier) => {
        expect(supplier.tenant_id).toBe(tenantA.id);
      });
    });

    it("should prevent cross-tenant access by ID", async () => {
      const userA = await createUser({ tenant: tenantA });
      const supplierB = await createSupplier({ tenant: tenantB });

      const response = await api.get(`/suppliers/${supplierB.id}`, {
        auth: userA,
      });

      expect(response.status).toBe(404);
    });

    it("should prevent tenant_id manipulation in POST", async () => {
      const userA = await createUser({ tenant: tenantA });

      const response = await api.post("/suppliers", {
        auth: userA,
        body: {
          name: "Malicious Supplier",
          tenant_id: tenantB.id, // Attempting to inject into tenant B
        },
      });

      expect(response.status).toBe(201);

      // Verify created in user's tenant, not injected tenant
      const created = await db.suppliers.findById(response.data.id);
      expect(created.tenant_id).toBe(tenantA.id);
      expect(created.tenant_id).not.toBe(tenantB.id);
    });
  });

  describe("Search & Filter Isolation", () => {
    it("should not return cross-tenant results in search", async () => {
      const userA = await createUser({ tenant: tenantA });
      await createSupplier({ tenant: tenantA, name: "Acme Corp" });
      await createSupplier({ tenant: tenantB, name: "Acme Industries" });

      const response = await api.get("/suppliers?search=Acme", {
        auth: userA,
      });

      expect(response.data).toHaveLength(1);
      expect(response.data[0].tenant_id).toBe(tenantA.id);
    });

    it("should not leak tenant existence in aggregations", async () => {
      const userA = await createUser({ tenant: tenantA });

      const response = await api.get("/analytics/supplier-count");

      // Should only count tenant A's suppliers
      expect(response.data.total).toBe(10);
      // NOT 30 (sum of all tenants)
    });
  });

  describe("Relationship Isolation", () => {
    it("should prevent cross-tenant foreign key references", async () => {
      const userA = await createUser({ tenant: tenantA });
      const supplierB = await createSupplier({ tenant: tenantB });

      // Attempt to create evaluation for tenant B's supplier
      const response = await api.post("/evaluations", {
        auth: userA,
        body: {
          supplier_id: supplierB.id,
          period_start: "2025-10-01",
          period_end: "2025-12-31",
        },
      });

      // Should fail (supplier not found in user's tenant)
      expect(response.status).toBe(400);
      expect(response.data.error).toBe("supplier_not_found");
    });
  });

  describe("File Storage Isolation", () => {
    it("should prevent cross-tenant file access", async () => {
      const userA = await createUser({ tenant: tenantA });
      const userB = await createUser({ tenant: tenantB });

      // User B uploads file
      const upload = await api.post("/documents", {
        auth: userB,
        body: { file: "confidential.pdf" },
      });

      // User A attempts to access
      const response = await api.get(`/documents/${upload.data.id}`, {
        auth: userA,
      });

      expect(response.status).toBe(404);
    });

    it("should store files with tenant prefix", async () => {
      const userA = await createUser({ tenant: tenantA });

      const upload = await api.post("/documents", {
        auth: userA,
        body: { file: "test.pdf" },
      });

      const storagePath = upload.data.storage_path;
      expect(storagePath).toMatch(new RegExp(`^${tenantA.id}/`));
    });
  });

  describe("Cache Isolation", () => {
    it("should include tenant_id in cache keys", async () => {
      const userA = await createUser({ tenant: tenantA });
      const userB = await createUser({ tenant: tenantB });

      // User A requests dashboard
      await api.get("/dashboard", { auth: userA });

      // Check cache key
      const cacheKey = await redis.keys("dashboard:*");
      expect(cacheKey[0]).toContain(tenantA.id);

      // User B requests dashboard
      await api.get("/dashboard", { auth: userB });

      // Should have separate cache entry
      const cacheKeys = await redis.keys("dashboard:*");
      expect(cacheKeys).toHaveLength(2);
      expect(cacheKeys.some((key) => key.includes(tenantB.id))).toBe(true);
    });
  });

  describe("SQL Injection Attempts", () => {
    it("should prevent RLS bypass via SQL injection", async () => {
      const userA = await createUser({ tenant: tenantA });

      const injections = [
        "' OR tenant_id != tenant_id OR name LIKE '",
        "'; DROP TABLE suppliers; --",
        "' UNION SELECT * FROM suppliers WHERE '1'='1",
        "1' OR '1'='1",
      ];

      for (const injection of injections) {
        const response = await api.get("/suppliers", {
          auth: userA,
          query: { search: injection },
        });

        // Should return only tenant A data (or empty)
        expect(response.data.length).toBeLessThanOrEqual(10);
        response.data.forEach((supplier) => {
          expect(supplier.tenant_id).toBe(tenantA.id);
        });
      }
    });
  });

  describe("Concurrent Multi-Tenant Load", () => {
    it("should handle concurrent requests from multiple tenants", async () => {
      const users = await Promise.all([
        createUser({ tenant: tenantA }),
        createUser({ tenant: tenantB }),
        createUser({ tenant: tenantC }),
      ]);

      // Simulate 100 concurrent requests across 3 tenants
      const requests = [];
      for (let i = 0; i < 100; i++) {
        const user = users[i % 3];
        requests.push(api.get("/suppliers", { auth: user }));
      }

      const responses = await Promise.all(requests);

      // Verify each response has correct tenant data
      responses.forEach((response, i) => {
        const expectedTenant = users[i % 3].tenant_id;
        response.data.forEach((supplier) => {
          expect(supplier.tenant_id).toBe(expectedTenant);
        });
      });
    });
  });
});
```

### 5.3 RLS Policy Testing

**Test Supabase Row-Level Security policies:**

```sql
-- Test RLS policies directly in database
-- tests/database/rls.test.sql

-- Setup: Create test tenants and data
INSERT INTO tenants (id, name) VALUES
  ('tenant-a', 'Tenant A'),
  ('tenant-b', 'Tenant B');

INSERT INTO suppliers (id, tenant_id, name) VALUES
  ('supplier-a1', 'tenant-a', 'Supplier A1'),
  ('supplier-a2', 'tenant-a', 'Supplier A2'),
  ('supplier-b1', 'tenant-b', 'Supplier B1');

-- Test: User from tenant A can only see tenant A suppliers
SET app.current_tenant = 'tenant-a';
SELECT COUNT(*) FROM suppliers; -- Should return 2

-- Test: Query for tenant B supplier should return 0 rows
SELECT COUNT(*) FROM suppliers WHERE id = 'supplier-b1'; -- Should return 0

-- Test: Cannot update other tenant's data
UPDATE suppliers SET name = 'Hacked' WHERE tenant_id = 'tenant-b';
SELECT name FROM suppliers WHERE id = 'supplier-b1'; -- Should still be 'Supplier B1'

-- Test: Cannot insert with wrong tenant_id
INSERT INTO suppliers (id, tenant_id, name) VALUES
  ('supplier-hack', 'tenant-b', 'Malicious Supplier');
-- Should fail or insert with tenant-a

SELECT tenant_id FROM suppliers WHERE id = 'supplier-hack';
-- Should be 'tenant-a', not 'tenant-b'
```

