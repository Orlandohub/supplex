{
  "extends": "../../packages/config/tsconfig.base.json",
  "compilerOptions": {
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "types": [
      "@react-router/node",
      "vite/client",
      "vitest/globals",
      "@testing-library/jest-dom"
    ],
    "paths": {
      "~/*": ["./app/*"],
      "@supplex/types": ["../../packages/types/src"],
      "@supplex/ui": ["../../packages/ui/src"]
    }
  },
  "include": [
    ".react-router/types/**/*",
    "app/**/*",
    "**/*.test.ts",
    "**/*.test.tsx",
    "vite.config.ts",
    "react-router.config.ts"
  ],
  "exclude": ["node_modules", "build", ".cache", ".react-router"]
}
