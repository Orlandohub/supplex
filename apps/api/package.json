{
  "name": "@supplex/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --import tsx --watch src/index.ts",
    "dev:bun": "bun run --watch src/index.ts",
    "build": "tsc && node build/index.js",
    "build:bun": "bun build src/index.ts --outdir ./dist --target bun",
    "start": "node dist/index.js",
    "start:bun": "bun run dist/index.js",
    "test": "vitest",
    "test:bun": "bun test",
    "lint": "eslint src/",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.0.2",
    "@supabase/supabase-js": "^2.75.0",
    "@supplex/db": "workspace:*",
    "@supplex/types": "workspace:*",
    "drizzle-orm": "^0.30.10",
    "elysia": "^1.0.0",
    "postgres": "^3.4.4",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@supplex/config": "workspace:*",
    "@types/bun": "^1.1.0",
    "@types/node": "^20.0.0",
    "drizzle-kit": "^0.21.4",
    "eslint": "^8.57.0",
    "tsx": "^4.0.0",
    "typescript": "^5.3.3",
    "vitest": "^1.0.0"
  }
}
