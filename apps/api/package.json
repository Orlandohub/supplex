{
  "name": "@supplex/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts | npx pino-pretty",
    "build": "bun build src/index.ts --outdir ./dist --target bun --minify",
    "start": "NODE_ENV=production bun run dist/index.js",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist node_modules"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.0.2",
    "@supabase/supabase-js": "^2.75.0",
    "@supplex/db": "workspace:*",
    "@supplex/types": "workspace:*",
    "bullmq": "^5.4.0",
    "drizzle-orm": "^0.30.10",
    "elysia": "~1.4.4",
    "file-type": "^22.0.0",
    "ioredis": "^5.3.0",
    "jose": "^5.10.0",
    "jsonwebtoken": "^9.0.2",
    "pdfkit": "^0.15.0",
    "pino": "^10.3.1",
    "postgres": "^3.4.4",
    "resend": "^1.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@elysiajs/eden": "~1.4.4",
    "@supplex/config": "workspace:*",
    "@types/bun": "^1.1.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.0.0",
    "@types/pdfkit": "^0.13.4",
    "drizzle-kit": "^0.21.4",
    "eslint": "^8.57.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.0.0",
    "typescript": "^5.3.3",
    "vitest": "^1.0.0"
  }
}
