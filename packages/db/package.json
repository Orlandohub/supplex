{
  "name": "@supplex/db",
  "version": "1.0.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "test": "bun test",
    "lint": "eslint src/",
    "type-check": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:ci": "bun run scripts/migrate-ci.ts",
    "db:migrate:prod": "bun run scripts/migrate-production.ts",
    "db:rollback": "bun run scripts/rollback-migration.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/seed.ts",
    "create-auth-users": "tsx src/create-auth-users.ts",
    "create-test-users": "tsx src/create-test-users.ts"
  },
  "dependencies": {
    "@supplex/types": "workspace:*",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.30.10",
    "postgres": "^3.4.4"
  },
  "devDependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "@supplex/config": "workspace:*",
    "@types/bun": "^1.1.0",
    "drizzle-kit": "^0.21.4",
    "eslint": "^8.57.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
